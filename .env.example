# Copie este arquivo para .env e preencha com seus valores:
#   copy .env.example .env
#
# O arquivo .env nao e versionado (contem credenciais).

# === Docker Hub ===
DOCKER_HUB_USER=seu_usuario_dockerhub
DOCKER_HUB_TOKEN=
DOCKER_IMAGE_NAME=openshift-welcome-api
DOCKER_IMAGE_TAG=1.0

# === Red Hat / OpenShift ===
REDHAT_USERNAME=seu_usuario_redhat
OPENSHIFT_SERVER=https://api.sandbox.x8e5.p1.openshiftapps.com:6443
OPENSHIFT_TOKEN=
OPENSHIFT_PROJECT=seu-usuario-dev
OPENSHIFT_APP_NAME=welcome-api

# Estrategia de deploy: clean (remove recursos antigos) ou unique (nome/tag aleatorios)
DEPLOY_STRATEGY=clean

# === Aplicacao (local e container) ===
APP_PORT=3000
APP_ENVIRONMENT=OpenShift
NODE_ENV=development

# === Git (opcional) ===
GITHUB_USER=seu_usuario_github
GITHUB_REPO=openshift-welcome-api
